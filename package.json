{
  "name": "font-effects",
  "version": "1.0.1",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "scripts": {
    "dev": "node esbuild.config.mjs --dev",
    "build": "node esbuild.config.mjs",
    "cf:dev": "npm run build && wrangler pages dev dist --d1 DB=DB --persist-to .wrangler/state --port 8789",
    "cf:d1:migrate": "wrangler d1 migrations apply font-effects-gallery",
    "cf:d1:migrate:local": "wrangler d1 migrations apply DB --local --persist-to .wrangler/state"
  },
  "dependencies": {
    "@blueprintjs/core": "^6.17.1",
    "@blueprintjs/icons": "^6.13.0",
    "@blueprintjs/select": "^6.3.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "mobx": "^6.16.1",
    "mobx-react-lite": "^4.1.1",
    "normalize.css": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.110.0"
  }
}
